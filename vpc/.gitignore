# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*

# .tfplan files
*.tfplan

# Crash log files
crash.log

# .terraform.lock.hcl files (Terraform v0.15+)
terraform.lock.hcl

# Exclude any .tfvars files that contain sensitive information
*.auto.tfvars
*.auto.tfvars.json
*.tfvars
*.tfvars.json

# Ignore override files as they are usually used to override settings in .tfvars files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
terraform.rc
